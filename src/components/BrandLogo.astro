---
import { Image } from 'astro:assets';
import logo from '../assets/images/logo.png';
import logoIcon from '../assets/images/logo-icon.png';

/**
 * 森半 tea&coffee のロゴ（支給 logo.png = マーク + 森半 + tea&coffee のロックアップ）。
 * 白抜き素材なので濃色背景の上でのみ使う（左 chrome / フッター / About はいずれも濃緑）。
 * markOnly は支給の logo-icon.png（マーク単体）を描画する（About）。
 * 表示幅は置き先（p-chrome-left__logo / p-footer__logo / p-about__mark）で指定する。
 */
interface Props {
  class?: string;
  markOnly?: boolean;
  alt?: string;
}
const { class: className, markOnly = false, alt = '' } = Astro.props;
const source = markOnly ? logoIcon : logo;
---

<span class:list={['c-brand-logo', markOnly && 'c-brand-logo--mark-only', className]}>
  <Image class='c-brand-logo__image' src={source} alt={alt} format='webp' />
</span>
