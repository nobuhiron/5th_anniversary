---
/**
 * 森半 tea&coffee のロゴ。
 * 正式なロゴ SVG は支給待ち。現状はシンボルマーク（三日月＋3点）＋文字組みで代用する。
 * markOnly を渡すとシンボルマークだけを描画する（About セクションで使用）。
 */
interface Props {
  class?: string;
  markOnly?: boolean;
}
const { class: className, markOnly = false } = Astro.props;
---

<span class:list={['c-brand-logo', markOnly && 'c-brand-logo--mark-only', className]}>
  <svg class='c-brand-logo__mark' viewBox='0 0 48 48' aria-hidden='true'>
    <path
      d='M40 30a17 17 0 1 1-9-22 13.6 13.6 0 0 0 9 22Z'
      fill='currentColor'
      transform='rotate(-20 24 24)'></path>
    <circle cx='19' cy='15' r='4' fill='var(--brand-mark-hole)'></circle>
    <circle cx='29' cy='19' r='2.6' fill='var(--brand-mark-hole)'></circle>
    <circle cx='19' cy='26' r='2.2' fill='var(--brand-mark-hole)'></circle>
  </svg>
  {
    !markOnly && (
      <span class='c-brand-logo__text'>
        <span class='c-brand-logo__ja'>森半</span>
        <span class='c-brand-logo__en'>tea&amp;coffee</span>
      </span>
    )
  }
</span>
