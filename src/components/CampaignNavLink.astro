---
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<a href={href} class='c-nav-campaign__link'>
  <span class='c-nav-campaign__label'>{label}</span>
  <span class='c-nav-campaign__icon' aria-hidden='true'>
    <svg class='c-nav-campaign__chevron' viewBox='0 0 24 24' fill='none'>
      <circle cx='12' cy='12' r='11' fill='currentColor'></circle>
      <path
        d='M10 7l5 5-5 5'
        stroke='var(--nav-chevron-stroke)'
        stroke-width='2'
        stroke-linecap='round'
        stroke-linejoin='round'></path>
    </svg>
  </span>
</a>
