---
/**
 * 宝探しのポップアップ。3種のお道具ごとに 1 枚 + スタンプ帳（スタンプボタン用）。
 *
 * アイテムはタイトル（○○を見つけた！）とイラストで示し、本文は「そのカードを
 * 何番目に見つけたか（進捗）」だけで決まる（道具に依らず共通）。発見順は treasure.js
 * が found の並びから求め、data-treasure-show（order1 / order2 / done）で出し分ける。
 *   - 1 番目に見つけた: STAGE_BODIES[0]
 *   - 2 番目に見つけた: STAGE_BODIES[1]
 *   - 3 番目に見つけた（＝完了。どの道具でも良い＝最後にクリックしたカード）:
 *     タイトル・本文を差し替え、「特別セットを見る」CTA を出す。
 * 地色・アクセント（枠/×/タイトル/CTA/バッジ）は道具ごと（実測色）。
 */
import { Image } from 'astro:assets';
import TreasureCard from './TreasureCard.astro';
import treasureMatcha from '../assets/images/treasure-matcha.png';
import treasureChasen from '../assets/images/treasure-chasen.png';
import treasureWan from '../assets/images/treasure-wan.png';
import treasureLeaf from '../assets/images/treasure-leaf01.png';

// 本文は「そのカードを何番目に見つけたか（進捗）」だけで決まる。どの道具でも共通。
// アイテムの区別はタイトル（○○を見つけた！）とイラストで示す。
// [0]=1 番目 / [1]=2 番目。3 番目は完了メッセージ（DONE_BODY）。
const STAGE_BODIES = [
  'さあ、おいしいお茶を点てる準備を始めましょう。\n残りの道具も探してみてください。',
  'お茶を点てる準備が整ってきました。\n秘密のお茶会まであと一息です！',
] as const;

const POPUPS = [
  { item: 'matcha', name: '抹茶', img: treasureMatcha },
  { item: 'chasen', name: '茶筅', img: treasureChasen },
  { item: 'chawan', name: '茶碗', img: treasureWan },
] as const;

// 3 つ揃った“最後のカード”に出す完了メッセージ（本文と差し替え）。
const DONE_BODY =
  'おめでとうございます！\nすべての道具を見つけた方だけに、\n数量限定の特別セットをご用意しました。\n通常ページにはない限定商品を\nぜひご覧ください。';
---

{
  POPUPS.map((popup) => (
    <div
      class='p-treasure-popup'
      data-treasure-popup={popup.item}
      role='dialog'
      aria-modal='true'
      aria-labelledby={`treasure-popup-${popup.item}`}
      hidden
    >
      <div class={`p-treasure-popup__panel p-treasure-popup__panel--${popup.item}`}>
        <button
          type='button'
          class='p-treasure-popup__close'
          data-treasure-close
          aria-label='閉じる'
        >
          ×
        </button>

        <h2 id={`treasure-popup-${popup.item}`} class='p-treasure-popup__title'>
          <span data-treasure-show='order1 order2'>{popup.name}を見つけた！</span>
          <span class='p-treasure-popup__title-done' data-treasure-show='done' hidden>
            道具が揃った！<br />お茶会へようこそ
          </span>
        </h2>

        <span class='p-treasure-popup__figure'>
          <Image class='p-treasure-popup__illust' src={popup.img} alt='' format='webp' />
        </span>

        <div class='p-treasure-popup__box'>
          <p class='p-treasure-popup__body' data-treasure-show='order1'>
            {STAGE_BODIES[0]}
          </p>
          <p class='p-treasure-popup__body' data-treasure-show='order2' hidden>
            {STAGE_BODIES[1]}
          </p>
          <p class='p-treasure-popup__body' data-treasure-show='done' hidden>
            {DONE_BODY}
          </p>

          <p class='p-treasure-popup__count'>
            <span class='p-treasure-popup__count-figure'>
              <b data-treasure-count>1</b>/3
            </span>
            <span class='p-treasure-popup__count-unit'>個獲得</span>
          </p>

          <Image class='p-treasure-popup__leaf' src={treasureLeaf} alt='' format='webp' />
        </div>

        <a
          href='#campaign-special'
          class='p-treasure-popup__cta'
          data-treasure-show='done'
          hidden
        >
          特別セットを見る
          <span class='p-treasure-popup__cta-arrow' aria-hidden='true'>
            <svg viewBox='0 0 30 30' fill='none'>
              <circle cx='15' cy='15' r='15' fill='#fff' />
              <path
                d='M13 9.5l5.5 5.5-5.5 5.5'
                stroke='currentColor'
                stroke-width='2.2'
                stroke-linecap='round'
                stroke-linejoin='round'
              />
            </svg>
          </span>
        </a>
      </div>
    </div>
  ))
}

{/* スタンプ帳（左 chrome が消える幅で、スタンプボタンから開く） */}
<div
  class='p-treasure-popup'
  data-treasure-popup='stamps'
  role='dialog'
  aria-modal='true'
  aria-labelledby='treasure-popup-stamps'
  hidden
>
  <div class='p-treasure-popup__panel p-treasure-popup__panel--card'>
    <button type='button' class='p-treasure-popup__close' data-treasure-close aria-label='閉じる'>
      ×
    </button>

    <TreasureCard headingId='treasure-popup-stamps' />
  </div>
</div>
