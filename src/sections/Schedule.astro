---
import { Image } from 'astro:assets';
import TreasureTrigger from '../components/TreasureTrigger.astro';
import { SCHEDULE_CARDS } from '../data/schedule';
import scheduleBg from '../assets/images/schedule-bg.jpg';
import kumahan from '../assets/images/kumahan.png';
import calendarImage from '../assets/images/calendar.png';
import clickMatcha from '../assets/images/click-matcha.png';
import campaign01 from '../assets/images/campaign01.png';
import campaign02 from '../assets/images/campaign02.png';
import campaign03 from '../assets/images/campaign03.png';
import campaign04 from '../assets/images/campaign04.png';

// カード画像は見出しとピルまで焼き込まれた完成版。文字は alt で読み上げる。
const CARD_IMAGES: Record<string, ImageMetadata> = {
  campaign01,
  campaign02,
  campaign03,
  campaign04,
};
---

<section id='schedule' class='l-section p-schedule' aria-labelledby='schedule-heading'>
  <Image class='p-schedule__bg' src={scheduleBg} alt='' format='webp' />

  <div class='l-inner p-schedule__inner'>
    <Image class='p-schedule__mascot' src={kumahan} alt='' format='webp' />

    <p class='p-schedule__lead'>
      <span class='c-heading__lead'>お得が盛りだくさん</span>
    </p>

    <h2 id='schedule-heading' class='p-schedule__title'>
      5周年<br />キャンペーンスケジュール
    </h2>

    <p class='p-schedule__month'>
      <span class='p-schedule__month-num'>2026</span>年<span class='p-schedule__month-num'>8</span>月
    </p>

    {/* 閉じているときは上段カードの中ほどから下をグラデーションでフェードして隠す。
        カード群・注記・カレンダーをまとめて 1 つの開閉領域にする。 */}
    <div class='p-schedule__collapse' id='schedule-detail'>
      <ul class='p-schedule__cards'>
        {
          SCHEDULE_CARDS.map((card) => (
            <li class='p-schedule__card'>
              <Image
                class='p-schedule__card-image'
                src={CARD_IMAGES[card.id]}
                alt={`${card.en} ${card.title.replace(/\n/g, '')}`}
                format='webp'
              />
            </li>
          ))
        }
      </ul>

      <p class='p-schedule__notes'>
        ※期間:2026/8/1~31<br />
        ※詳細は、本頁の中部をご確認ください。
      </p>

      <div class='p-schedule__detail'>
        <TreasureTrigger
          item='matcha'
          label='抹茶'
          image={clickMatcha}
          class='p-schedule__treasure'
        />
        <Image
          class='p-schedule__calendar'
          src={calendarImage}
          alt='2026年8月のキャンペーンスケジュール。8/1〜8/17 Plus1キャンペーン第1弾、8/3 はちみつ紅茶セール、8/7〜8/8 ポイントUP DAY、8/20 毎月恒例SALE、8/21〜8/31 Plus1キャンペーン第2弾。'
          format='webp'
        />
      </div>
    </div>

    <button
      type='button'
      class='c-btn-toggle p-schedule__toggle'
      data-schedule-toggle
      aria-expanded='false'
      aria-controls='schedule-detail'
    >
      <span data-schedule-toggle-label>開く</span>
      <span class='c-btn-toggle__icon' aria-hidden='true'>
        <svg viewBox='0 0 30 30' fill='none'>
          <circle cx='15' cy='15' r='15' fill='currentColor'></circle>
          <path
            d='M10 13l5 5 5-5'
            stroke='var(--toggle-arrow)'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'></path>
        </svg>
      </span>
    </button>
  </div>
</section>
