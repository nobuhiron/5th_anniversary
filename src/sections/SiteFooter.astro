---
import BrandLogo from '../components/BrandLogo.astro';
import { FOOTER_NAV_ITEMS } from '../data/campaign-nav';
---

<footer class='p-footer'>
  {/* カンプ実測: フッター右上、前セクションとの境界にまたがる白い四角 */}
  <button type='button' class='p-footer__pagetop' data-pagetop aria-label='ページの先頭へ戻る'>
    <svg viewBox='0 0 8 17' fill='none' aria-hidden='true'>
      <path
        d='M4 16.5V1M1 4.5L4 1L7 4.5'
        stroke='currentColor'
        stroke-width='1.2'
        stroke-linecap='round'
        stroke-linejoin='round'></path>
    </svg>
  </button>

  <div class='l-inner p-footer__inner'>
    <p class='p-footer__logo'>
      <BrandLogo alt='森半 tea&amp;coffee' />
    </p>

    <nav class='p-footer__nav' aria-label='フッターナビゲーション'>
      <ul class='p-footer__list'>
        {
          FOOTER_NAV_ITEMS.map((item) => (
            <li class='p-footer__item'>
              <a href={item.href} class='p-footer__link'>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</footer>
