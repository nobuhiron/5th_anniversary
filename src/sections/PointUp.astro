---
import { Image } from 'astro:assets';
import { LIMITED_SALE, POINT_UP } from '../data/campaigns';
import pointUpImage from '../assets/images/nav-image-pointup.jpg';
import saleImage from '../assets/images/nav-image-sale.jpg';
import matchaLatte from '../assets/images/matcha-latte.png';

// 支給画像は還元率・ブランド名・「詳しく見る」バーまで焼き込まれた完成版（335x257）。
// 文言は alt で読み上げる。
---

<section id='point-up' class='l-section p-point-up' aria-labelledby='point-up-heading'>
  {/* 前セクション(CampaignNav)との境界の左端にまたがる抹茶ラテ（装飾） */}
  <Image class='p-point-up__matcha-latte' src={matchaLatte} alt='' format='webp' />

  <div class='l-inner p-point-up__inner'>
    <p class='p-point-up__watermark' aria-hidden='true'>Point-up sale</p>

    <p class='p-point-up__lead'>{POINT_UP.lead}</p>
    <span class='p-point-up__rule' aria-hidden='true'></span>

    <h2 id='point-up-heading' class='p-point-up__title'>
      <span class='p-point-up__title-en'>{POINT_UP.titleEn}</span>
      <span class='p-point-up__title-ja'>{POINT_UP.titleJa}</span>
    </h2>

    <p class='c-period p-point-up__period'>{POINT_UP.period}</p>

    <a href={POINT_UP.href} class='p-point-up__card'>
      <Image
        class='p-point-up__card-image'
        src={pointUpImage}
        alt={`対象5ブランド 全品+6％還元。${POINT_UP.brands.replace(/\n/g, '')}${POINT_UP.brandsEm} 詳しく見る`}
        format='webp'
      />
    </a>

    <p class='p-point-up__sale-lead'>{LIMITED_SALE.lead}</p>
    <p class='p-point-up__sale-title'>{LIMITED_SALE.title}</p>

    <p class='c-period p-point-up__period p-point-up__period--sale'>{LIMITED_SALE.period}</p>

    <a href={LIMITED_SALE.href} class='p-point-up__card'>
      <Image
        class='p-point-up__card-image'
        src={saleImage}
        alt='毎月恒例 スペシャルSALE 人気商品が驚きの価格に! 詳しく見る'
        format='webp'
      />
    </a>
  </div>

  <p class='p-point-up__outro'>
    周年期間の<br />お得なキャンペーンは<br />こちら
  </p>
</section>
